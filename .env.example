# Copy to `.env` and fill in your key(s). The .env file is gitignored.
#
#   cp .env.example .env

# ElevenLabs API key — required by scripts/01_generate_tts.py
# Get one at https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Optional: Copernicus Data Space credentials for the Sentinel-2 fallback
# download path in data-collection/01_sentinel2_download.py
COPERNICUS_USER=
COPERNICUS_PASS=
